VITE_MAINNET_RPC_URL=https://api.mainnet-beta.solana.com
VITE_OSOCIAL_SIGNER_URL=https://your-signer.example.com

MAINNET_RPC_URL=https://api.mainnet-beta.solana.com
OSOCIAL_PROGRAM_ID=EzkXptxPSfDUUsbHwfSkF7Buvca1RVPGohCPAVFeUHcX
OSOCIAL_PLATFORM_AUTHORITY=89EvL1MAom5V2nBp5ucvDVgeVm8hRUUJNe9sDgub5HXF
OSOCIAL_TREASURY=89EvL1MAom5V2nBp5ucvDVgeVm8hRUUJNe9sDgub5HXF
OSOCIAL_ALLOWED_ORIGIN=https://your-app.example.com
OSOCIAL_SIGNER_HOST=127.0.0.1
OSOCIAL_SIGNER_API_KEY=replace-with-server-side-secret
OSOCIAL_REQUIRE_USER_ALLOWLIST=false
OSOCIAL_ALLOWED_USERS=
# Production signer starts only when protected by API key/allowlist, unless this is explicitly true.
OSOCIAL_PUBLIC_SIGNER=false
OSOCIAL_RATE_LIMIT_MAX=60
OSOCIAL_MAX_BODY_BYTES=8192
OSOCIAL_MAX_POST_PACKET_BYTES=1024
OSOCIAL_MEDIA_DIR=.media
OSOCIAL_MEDIA_MAX_BYTES=10485760
# Set this to a public CDN/storage domain in production, for example https://media.your-app.example.com
OSOCIAL_PUBLIC_MEDIA_BASE_URL=
OSOCIAL_SIGNER_TLS_KEY=.cert/local-key.pem
OSOCIAL_SIGNER_TLS_CERT=.cert/local-cert.pem
# Default username sale price. Init/set-fee converts this USD target into lamports.
# For deterministic ops, set OSOCIAL_SOL_USD manually. If omitted, scripts fetch SOL/USD.
OSOCIAL_REGISTRATION_PRICE_USD=1
OSOCIAL_SOL_USD=
# Optional override: if set, scripts use this exact lamport fee instead of USD pricing.
OSOCIAL_REGISTRATION_FEE_LAMPORTS=
OSOCIAL_MIN_USER_BALANCE_LAMPORTS=50000
OSOCIAL_MIN_USER_BALANCE_LABEL=gas buffer

# Use a protected server/KMS path in production. Do not expose this to the frontend.
OSOCIAL_AUTHORITY_KEYPAIR=/secure/path/osocial-authority.json
